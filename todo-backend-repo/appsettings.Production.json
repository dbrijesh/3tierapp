{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AuthSettings": {
    "Cognito": {
      "Region": "${COGNITO_REGION}",
      "UserPoolId": "${COGNITO_USER_POOL_ID}",
      "ClientId": "${COGNITO_CLIENT_ID}"
    },
    "AzureAD": {
      "TenantId": "${AZURE_TENANT_ID}",
      "ClientId": "${AZURE_CLIENT_ID}"
    }
  }
}