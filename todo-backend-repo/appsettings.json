{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AuthSettings": {
    "Cognito": {
      "Region": "us-east-1",
      "UserPoolId": "us-east-1_XXXXXXXXX",
      "ClientId": "your-cognito-client-id"
    },
    "AzureAD": {
      "TenantId": "your-tenant-id",
      "ClientId": "your-azure-client-id"
    }
  }
}